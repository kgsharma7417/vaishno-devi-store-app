rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins Collection
    match /admins/{userId} {
      // Users can only read their own admin document to check their status
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only existing admins or Firebase Console can modify the admins collection
      allow write: if isAdmin();
    }

    // Settings Collection
    match /settings/{document=**} {
      // Anyone can read settings (like homepage slides, payment details)
      allow read: if true;
      // Only admins can modify settings
      allow write: if isAdmin();
    }

    // Products Collection
    match /products/{productId} {
      // Anyone can view products
      allow read: if true;
      // Only admins can add, update, or delete products
      allow write: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      // Admins can read all orders
      // Customers can read their own orders. 
      // Note: Because guest users track via phone number, we have to allow read for guests if they know the phone number/order ID.
      allow read: if true; 
      
      // Anyone can create a new order (checkout)
      allow create: if true;
      
      // Only admins can update or delete an order (e.g. changing status to Shipped/Delivered)
      allow update, delete: if isAdmin();
    }

    // Reviews Collection: Grahak reviews padh sakte hain, sirf logged-in user review add kar sakte hain
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Users Collection: Login hone par user ka profile save hota hai
    // Sirf admin sabhi users dekh sakta hai
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
