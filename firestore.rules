rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins Collection
    match /admins/{userId} {
      // Users can only read their own admin document to check their status
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only existing admins or Firebase Console can modify the admins collection
      allow write: if isAdmin();
    }

    // Settings Collection
    match /settings/{document=**} {
      // Anyone can read settings (like homepage slides, payment details)
      allow read: if true;
      // Only admins can modify settings
      allow write: if isAdmin();
    }

    // Products Collection
    match /products/{productId} {
      // Anyone can view products
      allow read: if true;
      // Admins can do anything. Normal users can ONLY update stock fields during checkout.
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity', 'sizesAndStock', 'isOutOfStock'])
      );
    }

    // Orders Collection
    match /orders/{orderId} {
      // Guest users need to read specific orders they placed (via localStorage IDs)
      allow get: if true;
      // Logged in users can list their own orders. Admins can list all.
      allow list: if isAdmin() || (request.auth != null && request.auth.token.email != null && resource.data.customerDetails.email == request.auth.token.email);
      
      // Anyone can create a new order (checkout)
      allow create: if true;
      
      // Only admins can update or delete an order (e.g. changing status to Shipped/Delivered)
      allow update, delete: if isAdmin();
    }

    // Reviews Collection: Grahak reviews padh sakte hain, sirf logged-in user review add kar sakte hain
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Users Collection: Login hone par user ka profile save hota hai
    // Sirf admin sabhi users dekh sakta hai
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
